		"dotenv": "^17.4.2",
		"prisma": "^7.8.0",
		"puppeteer-extra": "^3.3.6",
		"puppeteer-extra-plugin-stealth": "^2.11.2",
		"qrcode": "^1.5.4",
		"qrcode-terminal": "^0.12.0",
		"whatsapp-web.js": "^1.34.7",
		"zod": "^4.4.3"
	}
